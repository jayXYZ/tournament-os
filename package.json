{
  "name": "tournament-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:frontend & pnpm run dev:backend",
    "dev:frontend": "pnpm --filter @tournament-os/web dev",
    "dev:backend": "pnpm --filter @tournament-os/backend dev",
    "build": "pnpm --filter @tournament-os/web build",
    "start": "pnpm --filter @tournament-os/web start",
    "lint": "pnpm --filter @tournament-os/web lint"
  }
}
