{
  "name": "tournament-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:frontend & pnpm run dev:backend",
    "dev:frontend": "pnpm --filter @tournament-os/web dev",
    "dev:backend": "pnpm --filter @tournament-os/backend dev",
    "dev:native": "pnpm --filter @tournament-os/native start",
    "db:wipe": "pnpm --filter @tournament-os/backend exec convex run maintenance:wipeAll",
    "build": "pnpm run build:web && pnpm run build:native",
    "build:web": "pnpm --filter @tournament-os/web build",
    "build:native": "pnpm --filter @tournament-os/native build",
    "start": "pnpm --filter @tournament-os/web start",
    "lint": "pnpm run lint:web && pnpm run lint:native",
    "lint:web": "pnpm --filter @tournament-os/web lint",
    "lint:native": "pnpm --filter @tournament-os/native lint"
  },
  "dependencies": {
    "expo": "~56.0.12",
    "react": "19.2.3",
    "react-native": "0.85.3"
  }
}
